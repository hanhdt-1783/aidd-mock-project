# Copy this file to `.env.local` and fill in real values.
# All NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.

# --- Supabase (required) ---
# Local defaults below match `supabase start`. For a hosted project, use the
# values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- Auth ---
# Path users land on after a successful login (handled by the OAuth callback).
NEXT_PUBLIC_AUTH_REDIRECT=/

# Public origin used to build the OAuth redirect URL.
# Optional in local dev (falls back to the request Origin). REQUIRED in
# production so Google redirects back to the correct host.
# Example: https://your-app.example.com
NEXT_PUBLIC_SITE_URL=
