# Google OAuth credentials for Supabase local — read by config.toml via env() substitution.
# Create OAuth client at https://console.cloud.google.com/apis/credentials with these settings:
#   - Application type: Web application
#   - Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
# Then copy this file to supabase/.env (gitignored) and paste real values.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
